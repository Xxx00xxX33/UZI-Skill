# UZI-Skill · 本地环境变量（可选）
# 把本文件复制为 .env 并填入你自己的值：
#   cp .env.example .env
#   # 然后编辑 .env 填 key

# ─── 东财妙想 Skills Hub API（推荐配置）──────────────────────
# 设置后 UZI-Skill 会优先使用官方 NLP API 做：
#   1. 中文名纠错（"北部港湾" 自动识别为 "北部湾港"）
#   2. 股票行情快照（稳定性远高于爬 push2.eastmoney.com）
# 获取 key（免费）: https://dl.dfcfs.com/m/itc4
MX_APIKEY=

# ─── Tushare Pro（可选备源）─────────────────────────────────────
# 默认数据链失败时，UZI 可把 Tushare 当作备用信息渠道之一。
# 若当前机器已部署 /opt/ai-trader 且其中 .env 含 TUSHARE_TOKEN，UZI 会优先复用该 token；
# 只有在你想显式覆盖时，才需要在这里单独填写。
# TUSHARE_TOKEN=

# ─── Telegram 群机器人（可选）─────────────────────────────────────
# 群里 @机器人 并附带股票代码后，触发 UZI 生成报告并回复临时链接
TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_ID=
# UZI_TELEGRAM_PORT=8988
# UZI_TELEGRAM_DEPTH=medium
# UZI_TELEGRAM_LINK_TTL_HOURS=24
# UZI_TELEGRAM_PYTHON=/root/UZI-Skill/.venv/bin/python

# ─── 其他可选 ─────────────────────────────────────────────
# STOCK_NO_CACHE=1        # 禁用所有 API 缓存，强制重新拉取
# UZI_NO_AUTO_OPEN=1      # 分析完不自动打开浏览器
